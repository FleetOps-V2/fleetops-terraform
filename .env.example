# ============================================================
# fleetops-terraform — Required GitHub Actions Secrets
# Configure these in: GitHub repo → Settings → Secrets → Actions
# ============================================================

# AWS OIDC role for GitHub Actions (terraform plan/apply/destroy)
# Value is printed after first bootstrap apply — see terraform output github_actions_role_arn
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/fleetops-github-actions-role

# GitHub App credentials (used by terraform-apply to push values-infra.yaml to fleetops-deployments)
APP_ID=
APP_PRIVATE_KEY=

# ============================================================
# Terraform input variables (sensitive — never commit actual values)
# ============================================================
TF_VAR_DB_PASSWORD=
TF_VAR_DB_USERNAME=postgres
TF_VAR_JWT_SECRET=
TF_VAR_GITHUB_PAT=
